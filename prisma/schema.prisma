generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Character {
  id                   String   @id @default(cuid())
  userId               String   @unique
  name                 String   @default("Adventurer")
  title                String   @default("Novice")
  class                String   @default("warrior")
  totalXp              Int      @default(0)
  level                Int      @default(1)
  hasCompletedTutorial Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String   @default("sword")
  color     String   @default("#dd6119")
  totalXp   Int      @default(0)
  level     Int      @default(1)

  discipline String?
  parentId String?
  parent   Skill?  @relation("SkillTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Skill[] @relation("SkillTree")

  quests          Quest[]
  secondaryQuests QuestSkill[] @relation("SecondarySkills")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([parentId])
  @@index([userId, discipline])
}

model Quest {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String   @default("")
  difficulty  Int      @default(2)
  xpReward    Int
  status      String   @default("active")
  isDaily     Boolean  @default(false)
  dailyCron   String?
  completedAt DateTime?

  skillId String?
  skill   Skill?  @relation(fields: [skillId], references: [id], onDelete: SetNull)

  chainId    String?
  chain      QuestChain? @relation(fields: [chainId], references: [id], onDelete: SetNull)
  chainOrder Int?

  completions     QuestCompletion[]
  secondarySkills QuestSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([chainId, chainOrder])
}

model QuestSkill {
  id      String @id @default(cuid())
  questId String
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation("SecondarySkills", fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([questId, skillId])
  @@index([questId])
  @@index([skillId])
}

model QuestChain {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  tier        String   @default("common")
  starred     Boolean  @default(false)
  starredAt   DateTime?
  quests      Quest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, starred])
}

model QuestCompletion {
  id          String   @id @default(cuid())
  userId      String
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  xpAwarded   Int
  completedAt DateTime @default(now())

  @@index([userId])
  @@index([completedAt])
  @@index([questId])
}

model DailyStreak {
  id            String    @id @default(cuid())
  userId        String
  questId       String
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastCompleted DateTime?

  @@unique([userId, questId])
  @@index([userId])
}

model Achievement {
  id          String    @id @default(cuid())
  userId      String
  key         String
  name        String
  description String
  icon        String    @default("trophy")
  category    String    @default("general")
  sortOrder   Int       @default(0)
  unlockedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, key])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
