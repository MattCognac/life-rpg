# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Optional — Supabase secret key for admin operations (account deletion)
# Find it in Supabase dashboard → Settings → API → Secret keys
SUPABASE_SECRET_KEY=""

# Database (Supabase Postgres)
# Transaction pooler (port 6543) for runtime queries — used by the app
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (port 5432) for migrations — bypasses PgBouncer transaction mode
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Optional — AI-generated quest chains
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
